{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "cmake",
    "protobuf",
    "SDL2",
    "SDL2_image",
    "SDL2_mixer",
    "glew",
    "libpng",
    "zlib",
    "pkg-config",
    "git",
    "libX11.dev"
  ],
  "shell": {
    "init_hook": [
      "echo 'RWE devbox shell ready.'"
    ],
    "scripts": {
      "build": [
        "mkdir -p build && cd build && cmake .. -G 'Unix Makefiles' -DCMAKE_BUILD_TYPE=Debug && make -j$(sysctl -n hw.ncpu 2>/dev/null || nproc)"
      ],
      "test": [
        "./build/rwe_test"
      ]
    }
  }
}
